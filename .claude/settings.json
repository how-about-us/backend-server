{
  "permissions": {
    "allow": [
      "Bash(./gradlew *)",
      "Bash(docker compose *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(git push origin main*)",
      "Bash(git push -u origin main*)",
      "Bash(git push -f origin main*)",
      "Bash(git push --force origin main*)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Read(**/.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./gradlew compileJava"
          },
          {
            "type": "command",
            "command": "jq -c 'if (.tool_input.file_path // \"\" | endswith(\".md\")) then {hookSpecificOutput: {hookEventName: \"PostToolUse\", additionalContext: (\"MD 파일이 수정됨: \" + (.tool_input.file_path // \"\") + \". checking-md-conflicts 스킬을 실행하여 충돌/중복을 점검하세요.\")}} else empty end'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  }
}
